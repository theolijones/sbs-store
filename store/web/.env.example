# Database — use a Postgres connection string for production (e.g. Vercel Postgres, Neon, Supabase)
# For local dev you can use SQLite: "file:./dev.db"
DATABASE_URL="file:./dev.db"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_A_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Registry URL
REGISTRY_URL="https://raw.githubusercontent.com/theolijones/sbs-store/main/store/registry.json"
